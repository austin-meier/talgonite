import { Theme } from "../theme.slint";
import { CharacterCreationState } from "../character_creation_state.slint";
import { LoginBridge } from "../login_bridge.slint";
import { LineEdit, Button, CheckBox } from "std-widgets.slint";
import { Icon } from "icon.slint";

struct HairColorOption { id: int, color: brush}

export component CharacterCreationScene inherits Rectangle {
    out property <[HairColorOption]> hair-colors: [
        { id: 5, color: #38b4a0 },
        { id: 9, color: #009400 },
        { id: 8, color: #889430 },
        { id: 4, color: #f8cc00 },
        { id: 10, color: #e86808 },
        { id: 2, color: #e04068 },
        { id: 7, color: #903090 },
        { id: 0, color: #783890 },
        { id: 13, color: #303080 },
        { id: 6, color: #5050c8 },
        { id: 12, color: #606078 },
        { id: 3, color: #a04000 },
        { id: 11, color: #704020 },
        { id: 1, color: #080808 }
    ];

    background: Theme.overlay-strong;

    TouchArea { }

    callback cancel();

    Rectangle {
        width: 600px;
        height: 360px;
        background: Theme.surface-modal;
        border-radius: Theme.radius-large;
        border-width: 1px;
        border-color: Theme.border-subtle;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        HorizontalLayout {
            padding: 24px;
            spacing: 24px;

            // Left side: Inputs
            VerticalLayout {
                width: 250px;
                spacing: 16px;
                alignment: center;

                Text {
                    text: "Create";
                    font-size: 18px;
                    font-weight: 700;
                    color: #E8C77F;
                    horizontal-stretch: 1;
                }

                LineEdit {
                    placeholder-text: "Name";
                    text <=> CharacterCreationState.username;
                    enabled: !CharacterCreationState.is-submitting;
                }

                LineEdit {
                    placeholder-text: "Password";
                    text <=> CharacterCreationState.password;
                    enabled: !CharacterCreationState.is-submitting;
                    input-type: password;
                }

                LineEdit {
                    placeholder-text: "Confirm";
                    text <=> CharacterCreationState.confirm-password;
                    enabled: !CharacterCreationState.is-submitting;
                    input-type: password;
                }

                HorizontalLayout {
                    spacing: 8px;
                    remember := CheckBox {
                        checked: true;
                        enabled: !CharacterCreationState.is-submitting;
                    }

                    Text {
                        text: "Save Password";
                        color: Theme.foreground-subtle;
                        vertical-alignment: center;
                    }
                }

                if (CharacterCreationState.error-message != ""): Text {
                    text: CharacterCreationState.error-message;
                    color: Theme.danger-foreground;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 20px;
                }

                HorizontalLayout {
                    spacing: 12px;
                    Button {
                        text: "Cancel";
                        enabled: !CharacterCreationState.is-submitting;
                        clicked => {
                            root.cancel()
                        }
                    }

                    Button {
                        text: "OK";
                        primary: true;
                        enabled: !CharacterCreationState.is-submitting;
                        clicked => {
                            LoginBridge.submit-character-creation();
                        }
                    }
                }
            }

            // Center: Character Preview & Controls
            Rectangle {
                width: 250px;
                background: Theme.surface-primary;
                border-radius: Theme.radius-medium;
                border-width: 1px;
                border-color: Theme.border-subtle;

                VerticalLayout {
                    padding: 16px;
                    spacing: 16px;
                    alignment: space-between;

                    // Gender toggle
                    HorizontalLayout {
                        spacing: 24px;
                        alignment: center;
                        male-button := Button {
                            transform-scale: 1.3;
                            text: "♂";
                            primary: CharacterCreationState.gender == 1;
                            clicked => {
                                LoginBridge.set-character-creation-gender(1);
                            }
                        }

                        female-button := Button {
                            transform-scale: 1.3;
                            text: "♀";
                            primary: CharacterCreationState.gender == 2;
                            clicked => {
                                LoginBridge.set-character-creation-gender(2);
                            }
                        }
                    }

                    // Preview Area
                    Rectangle {
                        height: 128px;
                        background: #00000040;
                        border-radius: Theme.radius-small;

                        Icon {
                            icon: CharacterCreationState.preview;
                            scale: 2.0;
                        }
                    }

                    // Hair Style
                    HorizontalLayout {
                        alignment: center;
                        spacing: 12px;
                        Button {
                            text: "◀";
                            clicked => {
                                LoginBridge.cycle-character-creation-hair-style(-1);
                            }
                        }

                        Text {
                            text: "Hair";
                            vertical-alignment: center;
                            color: Theme.foreground;
                        }

                        Button {
                            text: "▶";
                            clicked => {
                                LoginBridge.cycle-character-creation-hair-style(1);
                            }
                        }
                    }

                    // Hair Color Grid
                    HorizontalLayout {
                        alignment: center;
                        GridLayout {
                            spacing: 6px;

                            for color-opt[i] in root.hair-colors: Rectangle {
                                row: i / 7;
                                width: 18px;
                                height: 18px;
                                border-width: 1px;
                                border-color: CharacterCreationState.hair-color == color-opt.id ? Theme.foreground : Theme.border-subtle;
                                background: color-opt.color;

                                TouchArea {
                                    clicked => {
                                        LoginBridge.set-character-creation-hair-color(color-opt.id);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
