import { GameState } from "../game_state.slint";
import { Theme } from "../theme.slint";
import { VerticalBox, HorizontalBox, LineEdit, ScrollView } from "std-widgets.slint";
import { BasePanel } from "./base_panel.slint";
import { SkillList, SpellList } from "./skill_list.slint";

// Tab button — shared by all three tabs.
component CharacterTab inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();
    height: 32px;
    background: active ? Theme.accent-subtle : transparent;
    border-radius: Theme.radius-small;
    border-width: 1px;
    border-color: active ? Theme.accent-muted : transparent;
    Text {
        text: root.text;
        color: active ? Theme.accent : Theme.foreground-muted;
        font-weight: active ? 700 : 400;
        font-size: Theme.font-size-small;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea { clicked => root.clicked(); }
}

// One stat row: label | value | optional up-arrow button.
// The arrow is visible only when stat_points > 0.
component StatRow inherits Rectangle {
    in property <string> label;
    in property <int> value;
    in property <bool> can-raise: false;
    callback raise();

    height: 28px;

    HorizontalBox {
        padding-left: Theme.spacing-small;
        padding-right: Theme.spacing-small;
        spacing: 0px;

        Text {
            text: root.label;
            color: Theme.foreground-muted;
            font-size: Theme.font-size-small;
            font-weight: 700;
            vertical-alignment: center;
            width: 44px;
        }

        value-box := Rectangle {
            width: 48px;
            height: 22px;
            background: Theme.surface-card;
            border-radius: Theme.radius-small;
            border-width: 1px;
            border-color: Theme.border-muted;
            y: (parent.height - self.height) / 2;
            Text {
                text: root.value;
                color: Theme.foreground-strong;
                font-size: Theme.font-size-small;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Spacer
        Rectangle { }

        if root.can-raise: raise-btn := Rectangle {
            width: 22px;
            height: 22px;
            border-radius: Theme.radius-small;
            border-width: 1px;
            border-color: btn-touch.has-hover ? Theme.accent : Theme.border-muted;
            background: btn-touch.pressed ? Theme.accent-subtle : btn-touch.has-hover ? Theme.surface-secondary : Theme.surface-muted;
            y: (parent.height - self.height) / 2;
            animate background { duration: 80ms; }
            Text {
                text: "▲";
                font-size: 9px;
                color: btn-touch.has-hover ? Theme.accent : Theme.foreground-muted;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            btn-touch := TouchArea {
                clicked => { root.raise(); }
            }
        }
    }
}

// A labeled value pair — used for HP/MP/EXP/Gold etc.
component InfoRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 24px;

    HorizontalBox {
        padding-left: Theme.spacing-small;
        padding-right: Theme.spacing-small;
        spacing: 0px;

        Text {
            text: root.label;
            color: Theme.foreground-muted;
            font-size: Theme.font-size-xsmall;
            font-weight: 700;
            vertical-alignment: center;
            width: 72px;
        }

        val-box := Rectangle {
            height: 18px;
            background: Theme.surface-card;
            border-radius: Theme.radius-small;
            border-width: 1px;
            border-color: Theme.border-muted;
            y: (parent.height - self.height) / 2;
            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                Text {
                    text: root.value;
                    color: Theme.foreground-strong;
                    font-size: Theme.font-size-xsmall;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}

// Gold row with an amount input and drop button shown when gold > 0.
component GoldRow inherits Rectangle {
    height: GameState.player-gold > 0 ? 52px : 24px;

    VerticalLayout {
        spacing: 4px;

        // Label + current gold amount
        HorizontalBox {
            height: 24px;
            padding-left: Theme.spacing-small;
            padding-right: Theme.spacing-small;
            spacing: 0px;

            Text {
                text: "Gold";
                color: Theme.foreground-muted;
                font-size: Theme.font-size-xsmall;
                font-weight: 700;
                vertical-alignment: center;
                width: 72px;
            }

            val-box := Rectangle {
                height: 18px;
                background: Theme.surface-card;
                border-radius: Theme.radius-small;
                border-width: 1px;
                border-color: Theme.border-muted;
                y: (parent.height - self.height) / 2;
                HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 4px;
                    Text {
                        text: GameState.player-gold;
                        color: Theme.foreground-strong;
                        font-size: Theme.font-size-xsmall;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }

        // Amount input + drop button — only when player has gold
        if GameState.player-gold > 0: HorizontalBox {
            height: 24px;
            padding-left: Theme.spacing-small;
            padding-right: Theme.spacing-small;
            spacing: 0px;

            Text {
                text: "Amount";
                color: Theme.foreground-muted;
                font-size: Theme.font-size-xsmall;
                vertical-alignment: center;
                width: 72px;
            }

            // Stretches exactly like val-box above; LineEdit + Drop share its width
            Rectangle {
                height: 22px;
                y: (parent.height - self.height) / 2;

                HorizontalLayout {
                    spacing: 4px;

                    amount-edit := LineEdit {
                        text: "" + GameState.player-gold;
                        font-size: Theme.font-size-xsmall;
                        horizontal-stretch: 1;
                        min-width: 40px;
                    }

                    drop-btn := Rectangle {
                        width: 40px;
                        border-radius: Theme.radius-small;
                        border-width: 1px;
                        border-color: drop-touch.has-hover ? Theme.accent : Theme.border-muted;
                        background: drop-touch.pressed ? Theme.accent-subtle : drop-touch.has-hover ? Theme.surface-secondary : Theme.surface-muted;
                        animate background { duration: 80ms; }
                        Text {
                            text: "Drop";
                            font-size: Theme.font-size-xsmall;
                            color: drop-touch.has-hover ? Theme.accent : Theme.foreground-muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        drop-touch := TouchArea {
                            clicked => {
                                GameState.drop-gold(amount-edit.text);
                            }
                        }
                    }
                }
            }
        }
    }
}

// Labeled experience progress bar — reusable for both Level and Ability.
component ExpProgressBar inherits Rectangle {
    in property <string> label;
    in property <int> current;
    in property <int> remaining;
    in property <color> bar-color: Theme.accent;

    // fill = current / (current + remaining), clamped 0..1
    property <float> fill: (root.current + root.remaining) > 0
        ? Math.clamp(root.current * 1.0 / (root.current + root.remaining), 0.0, 1.0)
        : 0.0;

    height: 40px;
    background: Theme.surface-muted;
    border-radius: Theme.radius-small;
    border-width: 1px;
    border-color: Theme.border-muted;

    VerticalLayout {
        padding-top: 4px;
        padding-bottom: 4px;
        padding-left: Theme.spacing-small;
        padding-right: Theme.spacing-small;
        spacing: 4px;

        // Label row: "Level 45" on left, "12,345 to next" on right
        HorizontalLayout {
            height: 14px;
            Text {
                text: root.label;
                color: Theme.foreground-strong;
                font-size: Theme.font-size-small;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle { }

            Text {
                text: root.remaining + " to next";
                color: Theme.foreground-muted;
                font-size: Theme.font-size-xsmall;
                vertical-alignment: center;
                horizontal-alignment: right;
            }
        }

        // Bar track
        bar-track := Rectangle {
            height: 8px;
            border-radius: 4px;
            background: Theme.surface-card;
            border-width: 1px;
            border-color: Theme.border-muted;

            // Filled portion
            Rectangle {
                x: 0px;
                y: 0px;
                height: parent.height;
                width: Math.clamp(parent.width * root.fill, 0px, parent.width);
                border-radius: 4px;
                background: @linear-gradient(90deg, root.bar-color 0%, root.bar-color 100%);
                animate width { duration: 300ms; easing: ease-out; }
            }
        }
    }
}

// Stats tab content — primary stats with raise arrows + vitals.
component StatsTab inherits VerticalBox {
    spacing: Theme.spacing-small;
    padding: Theme.spacing-medium;
    alignment: start;

    // Unspent points banner — only shown when points > 0.
    if GameState.player-stat-points > 0: Rectangle {
        height: 24px;
        background: Theme.accent-subtle;
        border-radius: Theme.radius-small;
        border-width: 1px;
        border-color: Theme.accent-muted;
        Text {
            text: GameState.player-stat-points + " unspent stat point(s)";
            color: Theme.accent;
            font-size: Theme.font-size-xsmall;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Level & ability progress bars
    ExpProgressBar {
        label: "Level " + GameState.player-level;
        current: GameState.player-exp;
        remaining: GameState.player-exp-next;
        bar-color: Theme.accent;
    }

    ExpProgressBar {
        label: "Ability " + GameState.player-ab;
        current: GameState.player-ab-exp;
        remaining: GameState.player-ab-exp-next;
        bar-color: #60b0ff;
    }

    // Primary stats
    Rectangle {
        background: Theme.surface-muted;
        border-radius: Theme.radius-small;
        border-width: 1px;
        border-color: Theme.border-muted;
        height: stats-layout.preferred-height + 8px;

        stats-layout := VerticalLayout {
            padding: 4px;
            spacing: 0px;
            y: 4px;
            StatRow {
                label: "STR";
                value: GameState.player-str;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("str"); }
            }

            StatRow {
                label: "INT";
                value: GameState.player-int;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("int"); }
            }

            StatRow {
                label: "WIS";
                value: GameState.player-wis;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("wis"); }
            }

            StatRow {
                label: "CON";
                value: GameState.player-con;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("con"); }
            }

            StatRow {
                label: "DEX";
                value: GameState.player-dex;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("dex"); }
            }
        }
    }

    // Vitals + misc
    Rectangle {
        background: Theme.surface-muted;
        border-radius: Theme.radius-small;
        border-width: 1px;
        border-color: Theme.border-muted;
        height: vitals-layout.preferred-height + 8px;

        vitals-layout := VerticalLayout {
            padding: 4px;
            spacing: 0px;
            y: 4px;
            InfoRow {
                label: "HP";
                value: GameState.current_hp + " / " + GameState.max_hp;
            }

            InfoRow {
                label: "MP";
                value: GameState.current_mp + " / " + GameState.max_mp;
            }

            GoldRow { }

            InfoRow {
                label: "GP";
                value: GameState.player-gp;
            }

            InfoRow {
                label: "Weight";
                value: GameState.player-weight + " / " + GameState.player-max-weight;
            }
        }
    }

    // Combat secondary stats
    Rectangle {
        background: Theme.surface-muted;
        border-radius: Theme.radius-small;
        border-width: 1px;
        border-color: Theme.border-muted;
        height: combat-layout.preferred-height + 8px;

        combat-layout := VerticalLayout {
            padding: 4px;
            spacing: 0px;
            y: 4px;
            InfoRow {
                label: "Atk El";
                value: GameState.player-offense-element;
            }

            InfoRow {
                label: "Def El";
                value: GameState.player-defense-element;
            }

            InfoRow {
                label: "MR";
                value: GameState.player-magic-resistance;
            }

            InfoRow {
                label: "AC";
                value: GameState.player-armor-class;
            }

            InfoRow {
                label: "Damage";
                value: GameState.player-damage;
            }

            InfoRow {
                label: "Hit";
                value: GameState.player-hit;
            }
        }
    }

}

// The full character panel with three tabs.
export component CharacterPanel inherits BasePanel {
    in-out property <string> active-tab: "stats";
    title: "Character";
    width: 320px;
    height: 560px;
    close => {
        GameState.show-character = false;
    }

    VerticalBox {
        padding: Theme.spacing-medium;
        spacing: Theme.spacing-medium;

        // Tab bar
        HorizontalLayout {
            height: 32px;
            spacing: Theme.spacing-small;
            CharacterTab {
                text: "Stats";
                active: root.active-tab == "stats";
                clicked => { root.active-tab = "stats"; }
            }

            CharacterTab {
                text: "Skills";
                active: root.active-tab == "skills";
                clicked => { root.active-tab = "skills"; }
            }

            CharacterTab {
                text: "Spells";
                active: root.active-tab == "spells";
                clicked => { root.active-tab = "spells"; }
            }
        }

        // Tab content — subtract scrollbar width so content never underlaps it
        if root.active-tab == "stats": ScrollView {
            viewport-width: self.width - 16px;
            viewport-height: stats-content.preferred-height;
            stats-content := StatsTab { }
        }
        if root.active-tab == "skills": SkillList { }
        if root.active-tab == "spells": SpellList { }
    }
}
