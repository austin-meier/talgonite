import { GameState } from "../game_state.slint";
import { Theme } from "../theme.slint";
import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { BasePanel } from "./base_panel.slint";
import { SkillList, SpellList } from "./skill_list.slint";

// Tab button — shared by all three tabs.
component CharacterTab inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();
    height: 32px;
    background: active ? Theme.accent-subtle : transparent;
    border-radius: Theme.radius-small;
    border-width: 1px;
    border-color: active ? Theme.accent-muted : transparent;
    Text {
        text: root.text;
        color: active ? Theme.accent : Theme.foreground-muted;
        font-weight: active ? 700 : 400;
        font-size: Theme.font-size-small;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea { clicked => root.clicked(); }
}

// One stat row: label | value | optional up-arrow button.
// The arrow is visible only when stat_points > 0.
component StatRow inherits Rectangle {
    in property <string> label;
    in property <int> value;
    in property <bool> can-raise: false;
    callback raise();

    height: 28px;

    HorizontalBox {
        padding-left: Theme.spacing-small;
        padding-right: Theme.spacing-small;
        spacing: 0px;

        Text {
            text: root.label;
            color: Theme.foreground-muted;
            font-size: Theme.font-size-small;
            font-weight: 700;
            vertical-alignment: center;
            width: 44px;
        }

        value-box := Rectangle {
            width: 48px;
            height: 22px;
            background: Theme.surface-card;
            border-radius: Theme.radius-small;
            border-width: 1px;
            border-color: Theme.border-muted;
            y: (parent.height - self.height) / 2;
            Text {
                text: root.value;
                color: Theme.foreground-strong;
                font-size: Theme.font-size-small;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Spacer
        Rectangle { }

        if root.can-raise: raise-btn := Rectangle {
            width: 22px;
            height: 22px;
            border-radius: Theme.radius-small;
            border-width: 1px;
            border-color: btn-touch.has-hover ? Theme.accent : Theme.border-muted;
            background: btn-touch.pressed ? Theme.accent-subtle : btn-touch.has-hover ? Theme.surface-secondary : Theme.surface-muted;
            y: (parent.height - self.height) / 2;
            animate background { duration: 80ms; }
            Text {
                text: "▲";
                font-size: 9px;
                color: btn-touch.has-hover ? Theme.accent : Theme.foreground-muted;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            btn-touch := TouchArea {
                clicked => { root.raise(); }
            }
        }
    }
}

// A labeled value pair — used for HP/MP/EXP/Gold etc.
component InfoRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 24px;

    HorizontalBox {
        padding-left: Theme.spacing-small;
        padding-right: Theme.spacing-small;
        spacing: 0px;

        Text {
            text: root.label;
            color: Theme.foreground-muted;
            font-size: Theme.font-size-xsmall;
            font-weight: 700;
            vertical-alignment: center;
            width: 72px;
        }

        val-box := Rectangle {
            height: 18px;
            background: Theme.surface-card;
            border-radius: Theme.radius-small;
            border-width: 1px;
            border-color: Theme.border-muted;
            y: (parent.height - self.height) / 2;
            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                Text {
                    text: root.value;
                    color: Theme.foreground-strong;
                    font-size: Theme.font-size-xsmall;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}

// Stats tab content — primary stats with raise arrows + vitals.
component StatsTab inherits VerticalBox {
    spacing: Theme.spacing-small;
    padding: Theme.spacing-medium;

    // Unspent points banner — only shown when points > 0.
    if GameState.player-stat-points > 0: Rectangle {
        height: 24px;
        background: Theme.accent-subtle;
        border-radius: Theme.radius-small;
        border-width: 1px;
        border-color: Theme.accent-muted;
        Text {
            text: GameState.player-stat-points + " unspent stat point(s)";
            color: Theme.accent;
            font-size: Theme.font-size-xsmall;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Primary stats
    Rectangle {
        background: Theme.surface-muted;
        border-radius: Theme.radius-small;
        border-width: 1px;
        border-color: Theme.border-muted;
        height: stats-layout.preferred-height + 8px;

        stats-layout := VerticalLayout {
            padding: 4px;
            spacing: 0px;
            y: 4px;
            StatRow {
                label: "STR";
                value: GameState.player-str;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("str"); }
            }

            StatRow {
                label: "INT";
                value: GameState.player-int;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("int"); }
            }

            StatRow {
                label: "WIS";
                value: GameState.player-wis;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("wis"); }
            }

            StatRow {
                label: "CON";
                value: GameState.player-con;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("con"); }
            }

            StatRow {
                label: "DEX";
                value: GameState.player-dex;
                can-raise: GameState.player-stat-points > 0;
                raise => { GameState.spend-stat-point("dex"); }
            }
        }
    }

    // Vitals + progression
    Rectangle {
        background: Theme.surface-muted;
        border-radius: Theme.radius-small;
        border-width: 1px;
        border-color: Theme.border-muted;
        height: vitals-layout.preferred-height + 8px;

        vitals-layout := VerticalLayout {
            padding: 4px;
            spacing: 0px;
            y: 4px;
            InfoRow {
                label: "HP";
                value: GameState.current_hp + " / " + GameState.max_hp;
            }

            InfoRow {
                label: "MP";
                value: GameState.current_mp + " / " + GameState.max_mp;
            }

            InfoRow {
                label: "Level";
                value: GameState.player-level;
            }

            InfoRow {
                label: "EXP";
                value: GameState.player-exp;
            }

            InfoRow {
                label: "Next Lv";
                value: GameState.player-exp-next;
            }

            InfoRow {
                label: "Ability";
                value: GameState.player-ab;
            }

            InfoRow {
                label: "Ab.EXP";
                value: GameState.player-ab-exp;
            }

            InfoRow {
                label: "Next Ab";
                value: GameState.player-ab-exp-next;
            }

            InfoRow {
                label: "Gold";
                value: GameState.player-gold;
            }

            InfoRow {
                label: "GP";
                value: GameState.player-gp;
            }

            InfoRow {
                label: "Weight";
                value: GameState.player-weight + " / " + GameState.player-max-weight;
            }
        }
    }

    // Spacer so content doesn't stretch
    Rectangle { }
}

// The full character panel with three tabs.
export component CharacterPanel inherits BasePanel {
    in-out property <string> active-tab: "stats";
    title: "Character";
    width: 320px;
    height: 560px;
    close => {
        GameState.show-character = false;
    }

    VerticalBox {
        padding: Theme.spacing-medium;
        spacing: Theme.spacing-medium;

        // Tab bar
        HorizontalLayout {
            height: 32px;
            spacing: Theme.spacing-small;
            CharacterTab {
                text: "Stats";
                active: root.active-tab == "stats";
                clicked => { root.active-tab = "stats"; }
            }

            CharacterTab {
                text: "Skills";
                active: root.active-tab == "skills";
                clicked => { root.active-tab = "skills"; }
            }

            CharacterTab {
                text: "Spells";
                active: root.active-tab == "spells";
                clicked => { root.active-tab = "spells"; }
            }
        }

        // Tab content
        if root.active-tab == "stats": StatsTab { }
        if root.active-tab == "skills": SkillList { }
        if root.active-tab == "spells": SpellList { }
    }
}
