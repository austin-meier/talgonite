import {
    GameState,
    DragDropState,
    SlotPanelType,
    SocialStatusState,
    PanelLayoutState,
} from "../game_state.slint";
import { MailBoardState } from "../mail_board_state.slint";
import { InputBridge } from "../input_bridge.slint";
import { PlatformState } from "../platform_state.slint";
import { UiSettings } from "../ui-settings.slint";
import { SettingsState } from "../settings_state.slint";
import { NpcDialog } from "./menu_dialog.slint";
import { SettingsPanel } from "settings/panel.slint";
import { GameMenuPanel } from "settings/game_menu.slint";
import { Theme } from "../theme.slint";
import { InventoryPanel } from "./inventory_panel.slint";
import { ActionsPanel } from "./actions_panel.slint";
import { CharacterPanel } from "./character_panel.slint";
import { GameSidebar } from "./game_sidebar.slint";
import { WorldMap } from "./world_map.slint";
import { WorldLabels } from "./world_labels.slint";
import { HotBar } from "./hot_bar.slint";
import { PlayerHUD } from "./player_hud.slint";
import { ActionBarMessages } from "./action_bar_messages.slint";
import { ChatLog } from "./chat_log.slint";
import { PopupPanel } from "./popup_panel.slint";
import { ProfilePanel } from "./profile_panel.slint";
import { WorldContextMenuOverlay } from "./world_context_menu.slint";
import { WorldListPanel } from "./world_list.slint";
import { MailBoardPanel } from "./mail_board_panel.slint";
import {
    SocialStatusDropdown,
    SocialStatusDropdownOverlay,
} from "./social_status_panel.slint";
import { GroupPanel } from "./group_panel.slint";
import { GroupInvitePopup } from "./group_invite_popup.slint";
import {
    PopupState,
    ContextMenuState,
    NpcDialogState,
} from "../game_state.slint";
import {
    HorizontalBox,
    VerticalBox,
    ScrollView,
    LineEdit,
    Button,
} from "std-widgets.slint";

export component GameScene inherits Rectangle {
    callback request-snapshot();
    background: transparent;
    property <string> actions-tab: "skills";
    focus-scope := FocusScope {
        key-pressed(event) => {
            if (event.text == "\n") {
                chat-log.focus-input();
                return accept;
            }
            if (event.text == "\"") {
                chat-log.enter-whisper-mode();
                return accept;
            }
            if (event.text == "\u{001b}") { // Escape
                if (SettingsState.show-settings) {
                    SettingsState.show-settings = false;
                    SettingsState.show-game-menu = true;
                    return accept;
                }
                SettingsState.show-game-menu = !SettingsState.show-game-menu;
                return accept;
            }
            if (SettingsState.is-rebinding) {
                if (InputBridge.rebind-key-event(event)) {
                    return accept;
                }
            }
            return InputBridge.key-pressed(event);
        }
        key-released(event) => InputBridge.key-released(event);
    }

    TouchArea {
        pointer-event(event) => {
            InputBridge.pointer-event(event, self.mouse-x, self.mouse-y);
            DragDropState.maybe-drop(SlotPanelType.world, 0, self.mouse-x, self.mouse-y);
        }
        double-clicked => {
            InputBridge.double-click(self.mouse-x, self.mouse-y);
        }
        scroll-event(event) => InputBridge.scroll-event(self.mouse-x, self.mouse-y, event.delta-x / 1px, event.delta-y / 1px);
        clicked => {
            focus-scope.focus();
        }
    }

    // World-space labels (entity names, speech bubbles) rendered in screen space
    WorldLabels {
        width: 100%;
        height: 100%;
    }

    if (GameState.casting-indicator.visible): Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2 + 50px;
        width: 120px;
        height: 16px;
        background: #00000088;
        border-radius: 11px;
        border-width: 1px;
        border-color: #ffffff44;

        fill := Rectangle {
            x: 1px;
            y: 1px;
            width: (parent.width - 2px) * Math.clamp(GameState.casting-indicator.progress, 0.0, 1.0);
            height: parent.height - 2px;
            background: Theme.accent;
            border-radius: 4px;
        }

        txt := Text {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            text: GameState.casting-indicator.text;
            color: white;
            font-size: 10px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
            stroke: #000000aa;
            stroke-width: 1px;
        }
    }

    player-hud := PlayerHUD {
        x: 20px;
        y: 20px;
    }

    ActionBarMessages {
        x: 20px;
        y: player-hud.y + player-hud.height + 8px;
    }

    chat-log := ChatLog {
        x: 20px;
        y: parent.height - self.height - 20px;
        visible: !PlatformState.is-android;
        chat-sent => {
            focus-scope.focus();
        }
    }

    GameSidebar {
        x: parent.width - 64px;
        y: 0px;
    }

    // Hot bar at bottom right
    HotBar {
        x: parent.width - self.width - Theme.spacing-small;
        y: parent.height - self.height - Theme.spacing-small;
    }

    if (GameState.show-inventory): InventoryPanel {
        property <length> press-offset-x: 0;
        property <length> press-offset-y: 0;
        x: PanelLayoutState.resolve-x(PanelLayoutState.inventory-x, parent.width - 420px);
        y: PanelLayoutState.resolve-y(PanelLayoutState.inventory-y, 60px);
        draggable: true;
        drag-pressed(abs-x, abs-y) => {
            press-offset-x = abs-x - self.x;
            press-offset-y = abs-y - self.y;
        }
        drag-moved(abs-x, abs-y) => {
            PanelLayoutState.inventory-x = clamp(abs-x - press-offset-x, 0px, parent.width - self.width);
            PanelLayoutState.inventory-y = clamp(abs-y - press-offset-y, 0px, parent.height - self.height);
        }
        drag-released => {
            PanelLayoutState.move-request("inventory", PanelLayoutState.inventory-x, PanelLayoutState.inventory-y);
        }
    }
    if (GameState.show-world-list): WorldListPanel {
        property <length> press-offset-x: 0;
        property <length> press-offset-y: 0;
        x: PanelLayoutState.resolve-x(PanelLayoutState.world-list-x, parent.width - 470px);
        y: PanelLayoutState.resolve-y(PanelLayoutState.world-list-y, 60px);
        draggable: true;
        drag-pressed(abs-x, abs-y) => {
            press-offset-x = abs-x - self.x;
            press-offset-y = abs-y - self.y;
        }
        drag-moved(abs-x, abs-y) => {
            PanelLayoutState.world-list-x = clamp(abs-x - press-offset-x, 0px, parent.width - self.width);
            PanelLayoutState.world-list-y = clamp(abs-y - press-offset-y, 0px, parent.height - self.height);
        }
        drag-released => {
            PanelLayoutState.move-request("world_list", PanelLayoutState.world-list-x, PanelLayoutState.world-list-y);
        }
    }
    if (GameState.show-group): GroupPanel {
        property <length> press-offset-x: 0;
        property <length> press-offset-y: 0;
        x: PanelLayoutState.resolve-x(PanelLayoutState.group-x, parent.width - 350px);
        y: PanelLayoutState.resolve-y(PanelLayoutState.group-y, 60px);
        draggable: true;
        drag-pressed(abs-x, abs-y) => {
            press-offset-x = abs-x - self.x;
            press-offset-y = abs-y - self.y;
        }
        drag-moved(abs-x, abs-y) => {
            PanelLayoutState.group-x = clamp(abs-x - press-offset-x, 0px, parent.width - self.width);
            PanelLayoutState.group-y = clamp(abs-y - press-offset-y, 0px, parent.height - self.height);
        }
        drag-released => {
            PanelLayoutState.move-request("group", PanelLayoutState.group-x, PanelLayoutState.group-y);
        }
    }
    if (GameState.show-skills || GameState.show-spells): ActionsPanel {
        property <length> press-offset-x: 0;
        property <length> press-offset-y: 0;
        x: PanelLayoutState.resolve-x(PanelLayoutState.actions-x, parent.width - 490px);
        y: PanelLayoutState.resolve-y(PanelLayoutState.actions-y, 60px);
        active-tab: actions-tab;
        draggable: true;
        drag-pressed(abs-x, abs-y) => {
            press-offset-x = abs-x - self.x;
            press-offset-y = abs-y - self.y;
        }
        drag-moved(abs-x, abs-y) => {
            PanelLayoutState.actions-x = clamp(abs-x - press-offset-x, 0px, parent.width - self.width);
            PanelLayoutState.actions-y = clamp(abs-y - press-offset-y, 0px, parent.height - self.height);
        }
        drag-released => {
            PanelLayoutState.move-request("actions", PanelLayoutState.actions-x, PanelLayoutState.actions-y);
        }
    }
    if (GameState.show-character): CharacterPanel {
        property <length> press-offset-x: 0;
        property <length> press-offset-y: 0;
        x: PanelLayoutState.resolve-x(PanelLayoutState.character-x, parent.width - 490px);
        y: PanelLayoutState.resolve-y(PanelLayoutState.character-y, 60px);
        draggable: true;
        drag-pressed(abs-x, abs-y) => {
            press-offset-x = abs-x - self.x;
            press-offset-y = abs-y - self.y;
        }
        drag-moved(abs-x, abs-y) => {
            PanelLayoutState.character-x = clamp(abs-x - press-offset-x, 0px, parent.width - self.width);
            PanelLayoutState.character-y = clamp(abs-y - press-offset-y, 0px, parent.height - self.height);
        }
        drag-released => {
            PanelLayoutState.move-request("character", PanelLayoutState.character-x, PanelLayoutState.character-y);
        }
    }
    if (NpcDialogState.data.visible): NpcDialog {
        width: 100%;
        height: 100%;
    }
    if (SettingsState.show-settings): HorizontalLayout {
        alignment: center;
        VerticalLayout {
            alignment: center;
            preferred-width: 600px;
            SettingsPanel { }
        }
    }
    if (SettingsState.show-game-menu): VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            GameMenuPanel { }
        }
    }

    if (ContextMenuState.visible): WorldContextMenuOverlay {
        width: 100%;
        height: 100%;
        screen-width: parent.width;
        screen-height: parent.height;
    }

    // Profile panel (Equipment + Legends)
    if (GameState.profile.visible): ProfilePanel {
        property <length> press-offset-x: 0;
        property <length> press-offset-y: 0;
        x: PanelLayoutState.resolve-x(PanelLayoutState.profile-x, (parent.width - self.width) / 2);
        y: PanelLayoutState.resolve-y(PanelLayoutState.profile-y, (parent.height - self.height) / 2);
        draggable: true;
        drag-pressed(abs-x, abs-y) => {
            press-offset-x = abs-x - self.x;
            press-offset-y = abs-y - self.y;
        }
        drag-moved(abs-x, abs-y) => {
            PanelLayoutState.profile-x = clamp(abs-x - press-offset-x, 0px, parent.width - self.width);
            PanelLayoutState.profile-y = clamp(abs-y - press-offset-y, 0px, parent.height - self.height);
        }
        drag-released => {
            PanelLayoutState.move-request("profile", PanelLayoutState.profile-x, PanelLayoutState.profile-y);
        }
    }

    // Group invite popup (bottom-center, above hotbar)
    if (GameState.group-invite.visible): GroupInvitePopup {
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 120px;
    }

    // World map overlay (on top of normal UI)
    if (GameState.show-world-map): WorldMap {
        width: 100%;
        height: 100%;
    }

    if MailBoardState.visible: MailBoardPanel {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    PopupPanel {
        screen-width: parent.width;
        screen-height: parent.height;
    }

    init() => {
        focus-scope.focus();
    }
}
