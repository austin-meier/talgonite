component DesktopCollapsedCustomHotBarSlots inherits GridLayout {
    in property <int> offset: 0;
    spacing: 4px;

    for idx in 12: HotBarSlotView {
        row: 0;
        key-num: idx;
        panel-type: SlotPanelType.hotbar;
        slot: offset + idx;
        icon: GameState.hotbar[offset + idx].icon;
        name: GameState.hotbar[offset + idx].name;
        quantity: GameState.hotbar[offset + idx].quantity;
        cooldown-left: GameState.hotbar[offset + idx].cooldown.time_left;
        cooldown-total: GameState.hotbar[offset + idx].cooldown.total;
    }
}

component DesktopExpandedCustomHotBarSlotsThree inherits GridLayout {
    spacing: 4px;

    for idx in 36: HotBarSlotView {
        row: idx / 12;
        key-num: idx < 12 ? Math.mod(idx, 12) : -1;
        panel-type: SlotPanelType.hotbar;
        slot: idx;
        icon: GameState.hotbar[idx].icon;
        name: GameState.hotbar[idx].name;
        quantity: GameState.hotbar[idx].quantity;
        cooldown-left: GameState.hotbar[idx].cooldown.time_left;
        cooldown-total: GameState.hotbar[idx].cooldown.total;
    }
}

