        cooldown-total: GameState.hotbar[idx].cooldown.total;
    }
}

export component HotBar inherits Rectangle {
    property <bool> desktop-expanded: GameState.hotbar-row-count > 1;
    property <int> desktop-row-count: GameState.hotbar-row-count == 5 ? 5 : (GameState.hotbar-row-count == 3 ? 3 : 1);
    width: PlatformState.is-android ? 316px : 632px;
    height: PlatformState.is-android ? 104px : (desktop-row-count == 1 ? 56px : (desktop-row-count == 3 ? 152px : 248px));

    // Subtle fading background
    Rectangle {
        background: @linear-gradient(0deg, #00000025 0%, #00000012 10%, #00000040 20%, #00000040 80%, #00000025 90%, #00000000 100%);
        border-radius: 6px;
    }

    CancelDrag { }

    if PlatformState.is-android: HorizontalBox {
        padding: 6px;
        spacing: 4px;

        // Mode selector buttons - minimal dots
        VerticalLayout {
            spacing: PlatformState.is-android ? 2px : 1px;
            alignment: center;
            for i in 6: HotBarSelectorButton {
                selected: GameState.current-hotbar-panel == i;
                button-height: PlatformState.is-android ? 10px : 6px;
                activated => {
                    GameState.set-hotbar-panel(i);
                }
            }

            if PlatformState.is-android: Text {
                text: "\u{270E}";
                font-size: 14px;
                color: #808080;
                stroke: #00000080;
            }
        }

        if GameState.current-hotbar-panel == 0: InventorySlots { }
        if GameState.current-hotbar-panel == 1: SkillSlots { }
        if GameState.current-hotbar-panel == 2: SpellSlots { }
        if GameState.current-hotbar-panel == 3: CustomHotBarSlots {
            offset: 0;
        }
        if GameState.current-hotbar-panel == 4: CustomHotBarSlots {
            offset: 12;
        }
        if GameState.current-hotbar-panel == 5: CustomHotBarSlots {
            offset: 24;
        }
    }

    if !PlatformState.is-android: HorizontalBox {
        padding: 6px;
        spacing: 4px;

        if !desktop-expanded: VerticalLayout {
            spacing: desktop-expanded ? 6px : 2px;
            alignment: center;

            for i in 6: HotBarSelectorButton {
                selected: GameState.current-hotbar-panel == i;
                button-height: 6px;
                activated => {
                    GameState.set-hotbar-panel(i);
                }
            }
        }

        if desktop-expanded: VerticalLayout {
            spacing: 6px;
            alignment: center;

            for i in 4: HotBarSelectorButton {
                selected: i == 3 ? GameState.current-hotbar-panel >= 3 : GameState.current-hotbar-panel == i;
                button-height: 14px;
                activated => {
                    GameState.set-hotbar-panel(i);
                }
            }
        }

        if GameState.current-hotbar-panel == 0 && desktop-row-count == 1: DesktopInventorySlotsOne { }
        if GameState.current-hotbar-panel == 0 && desktop-row-count == 3: DesktopInventorySlotsThree { }
        if GameState.current-hotbar-panel == 0 && desktop-row-count == 5: DesktopInventorySlotsFive { }

        if GameState.current-hotbar-panel == 1 && desktop-row-count == 1: DesktopSkillSlotsOne { }
        if GameState.current-hotbar-panel == 1 && desktop-row-count == 3: DesktopSkillSlotsThree { }
        if GameState.current-hotbar-panel == 1 && desktop-row-count == 5: DesktopSkillSlotsFive { }

        if GameState.current-hotbar-panel == 2 && desktop-row-count == 1: DesktopSpellSlotsOne { }
        if GameState.current-hotbar-panel == 2 && desktop-row-count == 3: DesktopSpellSlotsThree { }
        if GameState.current-hotbar-panel == 2 && desktop-row-count == 5: DesktopSpellSlotsFive { }

        if !desktop-expanded && GameState.current-hotbar-panel == 3: DesktopCollapsedCustomHotBarSlots {
            offset: 0;
        }
        if !desktop-expanded && GameState.current-hotbar-panel == 4: DesktopCollapsedCustomHotBarSlots {
            offset: 12;
        }
        if !desktop-expanded && GameState.current-hotbar-panel == 5: DesktopCollapsedCustomHotBarSlots {
            offset: 24;
        }
        if desktop-expanded && GameState.current-hotbar-panel >= 3 && desktop-row-count == 3: DesktopExpandedCustomHotBarSlotsThree { }
        if desktop-expanded && GameState.current-hotbar-panel >= 3 && desktop-row-count == 5: DesktopExpandedCustomHotBarSlotsFive { }

        VerticalLayout {
            spacing: 4px;
            alignment: center;

            HotBarArrowButton {
                label: "▲";
                enabled: GameState.hotbar-row-count < 5;
                activated => {
                    GameState.expand-hotbar();
                }
            }

            HotBarArrowButton {
                label: "▼";
                enabled: GameState.hotbar-row-count > 1;
                activated => {
                    GameState.collapse-hotbar();
                }
            }
        }
    }
}
