        Rectangle {
            height: Theme.spacing-small;
        }

        SectionHeader {
            title: "Hotbar Slots";
        }

        Rectangle {
            height: 34px;
            background: transparent;
            toggle-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    SettingsState.modifier-hotbar-rows-target-custom-only = !SettingsState.modifier-hotbar-rows-target-custom-only;
                    SettingsState.modifier-hotbar-rows-target-custom-only-changed(SettingsState.modifier-hotbar-rows-target-custom-only);
                }
            }

            HorizontalBox {
                spacing: 12px;
                Rectangle {
                    width: 18px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: Theme.surface-card;
                    border-radius: Theme.radius-small;
                    border-width: 1px;
                    border-color: toggle-touch.has-hover ? Theme.accent : Theme.border-muted;
                    if SettingsState.modifier-hotbar-rows-target-custom-only: Rectangle {
                        x: 4px;
                        y: 4px;
                        width: 10px;
                        height: 10px;
                        border-radius: 2px;
                        background: Theme.accent;
                    }
                }

                Text {
                    text: "Modifier rows target custom hotbars only";
                    font-size: 13px;
                    color: Theme.foreground;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    width: 40px;
                    text: SettingsState.modifier-hotbar-rows-target-custom-only ? "On" : "Off";
                    font-size: 12px;
                    color: Theme.foreground-muted;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
            }
        }

