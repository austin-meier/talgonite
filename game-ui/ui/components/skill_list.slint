// Scrollable list of all skills. Drop-in composable.
export component SkillList inherits Rectangle {
    background: Theme.surface-muted;
    border-radius: Theme.radius-small;
    clip: true;

    ScrollView {
        width: 100%;
        height: 100%;
        viewport-width: self.visible-width;
        CancelDrag { }

        VerticalLayout {
            padding: 4px;
            spacing: 4px;
            alignment: start;
            for skill in GameState.skills: SkillListRow {
                skill: skill;
            }
        }
    }
}

// Scrollable list of all spells. Drop-in composable.
export component SpellList inherits Rectangle {
    background: Theme.surface-muted;
    border-radius: Theme.radius-small;
    clip: true;

    ScrollView {
        width: 100%;
        height: 100%;
        viewport-width: self.visible-width;
        CancelDrag { }

        VerticalLayout {
            padding: 4px;
            spacing: 4px;
            alignment: start;
            for spell in GameState.spells: SpellListRow {
                spell: spell;
            }
        }
    }
}
