import { GameState, WorldLabel, SpeechBubble } from "../game_state.slint";
import { Theme } from "../theme.slint";

component BaseWorldLabel inherits Rectangle {
    in property <float> world_x;
    in property <float> world_y;
    in property <float> y_offset;
    pure function world-to-screen-x(world_x: float) -> length {
        return (world_x - GameState.camera_x) * GameState.camera_zoom * GameState.display_scale * 1phx + (GameState.viewport_width * GameState.display_scale / 2.0) * 1phx;
    }
    pure function world-to-screen-y(world_y: float) -> length {
        return (world_y - GameState.camera_y) * GameState.camera_zoom * GameState.display_scale * 1phx + (GameState.viewport_height * GameState.display_scale / 2.0) * 1phx;
    }
    
    out property <length> screen_x: world-to-screen-x(world_x);
    out property <length> screen_y: world-to-screen-y(world_y + y_offset);
    out property <float> total_scale: GameState.camera_zoom * GameState.display_scale;
    out property <length> max_text_width: 180px;
    in property <length> label_padding: 4px;
    out property <length> bottom_offset: 8px * total_scale;
    
    x: screen_x - self.width / 2;
    y: screen_y - bottom_offset - self.height;
}

component LabelItem inherits BaseWorldLabel {
    in property <WorldLabel> label;
    world_x: label.world_x;
    world_y: label.world_y;
    y_offset: label.y_offset;
    label_padding: 4px;

    width: txt.width + root.label_padding * 2;
    height: txt.height + root.label_padding * 2;

    // Health Bar Container
    if (label.health_percent >= 0): Rectangle {
        y: -6px * root.total_scale;
        width: 16px * root.total_scale;
        height: 3px * root.total_scale;
        x: (parent.width - self.width) / 2;
        background: #000000cc;
        border-width: Math.floor(Math.max(1, 0.5 * root.total_scale)) * 1px;
        border-color: #ffffff33;

        // Health Fill
        Rectangle {
            x: parent.border-width;
            y: parent.border-width;
            width: (parent.width - 2 * parent.border-width) * min(100, max(0, label.health_percent)) / 100;
            height: parent.height - 2 * parent.border-width;
            background: label.health_percent > 50 ? #2ecc71 : (label.health_percent > 25 ? #f1c40f : #e74c3c);
        }
    }

    txt := Text {
        x: root.label_padding;
        y: root.label_padding;
        width: self.preferred-width;
        text: label.text;
        color: label.color;
        font-size: 11px;
        font-weight: 600;
        horizontal-alignment: center;
        stroke: #00000080;
        stroke-width: 2px;
    }
}

component SpeechBubbleItem inherits BaseWorldLabel {
    in property <SpeechBubble> label;
    world_x: label.world_x;
    world_y: label.world_y;
    y_offset: label.y_offset;
    label_padding: 8px;

    width: txt.width + root.label_padding * 2;
    height: txt.height + root.label_padding * 2;

    background: #00000075;
    border-radius: 10px;
    border-width: 1px;
    border-color: #ffffffdd;
    drop-shadow-blur: 4px;
    drop-shadow-color: #00000088;

    txt := StyledText {
        x: root.label_padding;
        y: root.label_padding;
        width: min(self.preferred-width, root.max_text_width);
        text: label.text;
        default-color: white;
        default-font-size: 11px;
        horizontal-alignment: center;
    }
}

export component WorldLabels inherits Rectangle {
    background: transparent;
    for label in GameState.world_labels: LabelItem {
        label: label;
    }
    for bubble in GameState.speech_bubbles: SpeechBubbleItem {
        label: bubble;
    }
}
